# My Claude Bot — переменные окружения
# Скопируй этот файл: cp .env.example .env
# Заполни значения и НЕ коммить .env в git!

# Домашняя директория пользователя (для Docker volumes)
# Нужна чтобы sudo docker compose корректно монтировал Claude CLI
HOST_HOME=/home/your_username

# Токен бота /me (получить у @BotFather в Telegram)
ME_BOT_TOKEN=your_bot_token_here

# Токен бота /coder (опционально)
CODER_BOT_TOKEN=your_coder_bot_token_here

# Токен бота Team Hub (опционально, командный ассистент для групп)
TEAM_BOT_TOKEN=your_team_bot_token_here

# Твой Telegram user ID (получить у @userinfobot)
FOUNDER_TELEGRAM_ID=your_telegram_id

# Deepgram API ключ для голосовых сообщений (опционально)
# Получить на https://console.deepgram.com/ — есть бесплатный тариф ($200 кредитов)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Backup — ночное резервное копирование агентов (ежедневно в 03:00 UTC)
# Команды: /backup_link, /backup_now, /backup_status
# BACKUP_URL и BACKUP_SECRET заполняются автоматически при первом запуске.
# Не трогай эти строки вручную.
BACKUP_URL=https://srvrhlthdrm.brewos.ru
BACKUP_SECRET=

# MCP серверы (опционально)
# GitHub: https://github.com/settings/tokens (scopes: repo, read:org)
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_token_here
# Todoist: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_token_here
# Google Calendar: OAuth2 credentials JSON
GOOGLE_CALENDAR_CREDENTIALS=your_calendar_credentials_here

# Skill Pool — маркетплейс скиллов
# По умолчанию бот использует публичный пул my-claude-bot-skills
# (https://github.com/dream77r/my-claude-bot-skills.git). Команды /poolskills
# и /installskill работают сразу без настройки.
#
# Переопределения (все опциональны):
#   SKILL_POOL_URL=<your-fork-url>   — использовать свой форк пула
#   SKILL_POOL_URL=disabled          — полностью отключить пул
#   SKILL_POOL_BRANCH=develop        — ветка пула (default: main)
#   SKILL_POOL_CACHE=<path>          — путь к кэшу (default: .cache/skill-pool)
SKILL_POOL_URL=
SKILL_POOL_BRANCH=main
SKILL_POOL_CACHE=
